# Never copy node_modules or runtime data from the host into the image.
node_modules

# Runtime data and generated files
data/
*.db
*.log
coverage/

# Config files with secrets (mounted at runtime)
.env
config.yaml

# VCS / CI
.git
.gitignore
.github

# Tests and lint/test tooling (not needed at runtime)
__tests__/
eslint.config.js
jest.config.js

# Docs and Docker metadata (not needed in the image)
*.md
Dockerfile
docker-compose.yml
.dockerignore
